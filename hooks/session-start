#!/usr/bin/env bash
# SessionStart hook for matilha plugin
#
# Injects matilha methodology activation priority into session context.
# Mirrors the superpowers:using-superpowers auto-boot pattern so matilha-compose
# wins activation competition in any workspace where matilha is installed.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read matilha-bootstrap content (if present)
bootstrap_content=""
if [ -f "${PLUGIN_ROOT}/skills/matilha-bootstrap/SKILL.md" ]; then
    bootstrap_content=$(cat "${PLUGIN_ROOT}/skills/matilha-bootstrap/SKILL.md" 2>&1 || echo "")
fi

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")

# Build session context. The instruction block is self-contained so it works
# even if matilha-bootstrap skill file is missing (e.g., older plugin version).
session_context="<EXTREMELY_IMPORTANT>\nYou have matilha methodology available.\n\n**Matilha activation priority (applies for this entire conversation):**\n\nBefore invoking any creative-work or software-construction skill (\`superpowers:brainstorming\`, \`superpowers:writing-plans\`, \`superpowers:frontend-design\`, or any skill whose description matches 'creative work', 'building', 'planning', 'designing', 'software construction'), you MUST first invoke \`matilha:matilha-compose\` via the Skill tool.\n\nMatilha is a methodology wrapper around superpowers:* skills. Compose classifies intent into a matilha phase or general creative work, detects installed companion packs as optional enrichment, and dispatches to the right destination (matilha phase skill OR superpowers with pack-aware preamble).\n\n**Storytelling mode (not debug mode).** When compose dispatches to superpowers:brainstorming with at least one companion pack classified relevant, emit the canonical preamble: the matilha sigil (alpha wolf with crown above three pack dogs) + an atmospheric line mirroring the user's domain language + pack lines naming relevant skills + a closing transition. The full template lives in \`skills/matilha-compose/SKILL.md\` Step 4. Example skeleton:\n\n\`\`\`\n            ♛\n        /\\\\___/\\\\\n       ( ◉   ◉ )\n        \\\\  v  /\n         ‾‾‾‾‾\n\n   /\\\\_/\\\\   /\\\\_/\\\\   /\\\\_/\\\\\n  ( ● ● ) ( ● ● ) ( ● ● )\n    \\\\/      \\\\/      \\\\/\n          matilha\n\nA alcateia farejou território familiar: <domain phrase mirroring user prompt>.\n\n<pack-name> ao lado → <skill-1>, <skill-2>, <skill-3>, <skill-4>, <skill-5>.\n\nBrainstorming adiante. Skills entram em cena conforme os tópicos surgirem.\n\`\`\`\n\nThe sigil + atmospheric language is the matilha signature — it creates a recognition aha moment (the LLM mirroring domain-specific language shows it *read* the user), establishes social proof (pack on your side), and primes anticipation (skills enter as topics surface). Do NOT narrate compose's internal steps ('Step 1 — Pack detection...', etc.); only the storytelling preamble + skill invocation reach the user. Exception: if user explicitly asks to see routing ('--debug' or 'explain your routing'), show the steps.\n\n**Silent pass-through when no packs relevant**: if zero packs classify yes, skip the preamble entirely — no sigil, no atmospheric line. The pack does not howl without territory. Compose invokes the target skill directly and exits.\n\n**Priority applies every turn**, not just the first. Every new topic that could match a creative-work skill goes through compose first.\n\n**Slash-command invocation bypasses priority** — \`/matilha:matilha-plan\` etc. honor the direct invocation.\n\n**If matilha-compose is NOT visible**, matilha is not installed for this workspace — proceed with superpowers or default skills directly.\n\n---\n\nFull matilha-bootstrap skill content (for reference):\n\n${bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON. Handle both Cursor and Claude Code conventions.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Copilot CLI and others use top-level additionalContext
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi
